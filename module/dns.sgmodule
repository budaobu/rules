#!name=DNS Host
#!desc=域名按所属 DNS 分流解析（稳定优化版）
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Server.png

[General]

# 让代理请求也使用 [Host] 中的 DNS 映射
use-local-host-item-for-proxy = true

# 不建议开启，否则 DoH 也会跟随代理规则
# 容易形成 DNS → Proxy → DNS 循环
encrypted-dns-follow-outbound-mode = false


[Host]

# =========================
# IPv6
# =========================

ip6-localhost = ::1
ip6-loopback = ::1
ip6-localnet = fe00::0
ip6-mcastprefix = ff00::0
ip6-allnodes = ff02::1
ip6-allrouters = ff02::2
ip6-allhosts = ff02::3


# =========================
# Bootstrap
# 给 DoH 域名提供初始解析
# 避免 bootstrap recursion
# =========================

# Tencent DNSPod
doh.pub = 119.29.29.29, 2402:4e00::
dot.pub = 119.29.29.29, 2402:4e00::

# AliDNS
dns.alidns.com = 223.5.5.5, 223.6.6.6
dns.alidns.com = 2400:3200:baba::1, 2400:3200::1

# Google DNS
dns.google = 8.8.8.8, 8.8.4.4
dns.google = 2001:4860:4860::8888, 2001:4860:4860::8844

# Cloudflare DNS
cloudflare-dns.com = 1.1.1.1, 1.0.0.1
cloudflare-dns.com = 2606:4700:4700::1111, 2606:4700:4700::1001

one.one.one.one = 1.1.1.1, 1.0.0.1
1dot1dot1dot1.cloudflare-dns.com = 1.1.1.1, 1.0.0.1

# Apple
doh.dns.apple.com = 17.253.21.202


# =========================
# Google
# =========================

# 这个域名本身用 Google DNS
*.ip.net.coffee = server:https://8.8.8.8/dns-query

# Google 中国 CDN / 下载
blog.google = server:https://doh.pub/dns-query
googletraveladservices.com = server:https://doh.pub/dns-query
dl.google.com = server:https://doh.pub/dns-query
dl.l.google.com = server:https://doh.pub/dns-query
clientservices.googleapis.com = server:https://doh.pub/dns-query
update.googleapis.com = server:https://doh.pub/dns-query
translate.googleapis.com = server:https://doh.pub/dns-query
fonts.googleapis.com = server:https://doh.pub/dns-query
fonts.gstatic.com = server:https://doh.pub/dns-query

# STUN 必须本地解析
stun.l.google.com = server:syslib
stun?.l.google.com = server:syslib


# =========================
# Apple
# =========================

networking.apple = server:https://doh.dns.apple.com/dns-query
*.icloud.com = server:https://doh.dns.apple.com/dns-query


# =========================
# OpenAI
# =========================

RULE-SET:https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/OpenAI/OpenAI.list = server:https://1.1.1.1/dns-query


# =========================
# Claude
# =========================

RULE-SET:https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Claude/Claude.list = server:https://1.1.1.1/dns-query


# =========================
# 腾讯
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/tencent.list = server:https://doh.pub/dns-query


# =========================
# 阿里
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/ali.list = server:quic://dns.alidns.com


# =========================
# Alphabet / Google
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/alphabet.list = server:https://8.8.8.8/dns-query


# =========================
# Cloudflare
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/cloudflare.list = server:https://1.1.1.1/dns-query


# =========================
# Bytedance
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/bytedance.list = server:180.184.1.1


# =========================
# 百度
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/baidu.list = server:180.76.76.76


# =========================
# Router / LAN
# =========================

RULE-SET:https://raw.githubusercontent.com/budaobu/rules/main/dns_mapping/router.list = server:syslib
